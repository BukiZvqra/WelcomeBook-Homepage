---
layout: base.njk
title: Контакти — TES Borovets
---
{% set lang = lang or "bg" %}
{% set t = i18n[lang] %}
{% set prefix = "" if lang == "bg" else "/en" %}

<!-- Breadcrumb -->
<nav class="breadcrumb" aria-label="breadcrumb">
  <div class="container">
    <ol class="breadcrumb-list">
      <li><a href="{{ prefix }}/">{{ t.breadcrumb_home }}</a></li>
      <li>
        <span class="bc-sep" aria-hidden="true">›</span>
        <span class="bc-current">{{ t.nav_contact }}</span>
      </li>
    </ol>
  </div>
</nav>

<!-- Page Header -->
<section class="page-intro">
  <div class="container">
    <h1>{{ t.contact_title }}</h1>
    <p class="lead">{{ t.contact_subtitle }}</p>
  </div>
</section>

<!-- Contact Methods -->
<section>
  <div class="container">
    <h2>{{ t.contact_methods_title }}</h2>
    <div style="margin-top: var(--space-5);">
      {% include "contact-methods.njk" %}
    </div>
    <p style="margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-neutral-500);">{{ t.contact_response_time }}</p>
  </div>
</section>

<!-- Contact Form -->
<section class="section-alt">
  <div class="container">
    <div style="max-width: var(--container-sm);">
      <h2>{{ t.contact_form_name | replace(t.contact_form_name, (t.contact_title if lang == "en" else "Форма за контакт")) }}</h2>

      <form name="contact"
            method="POST"
            data-netlify="true"
            style="margin-top: var(--space-6);">

        <input type="hidden" name="form-name" value="contact">

        <!-- Honeypot -->
        <div class="form-honey">
          <label>Don't fill this in: <input name="bot-field"></label>
        </div>

        <!-- Name -->
        <div class="form-group">
          <label for="contact-name">
            {{ t.contact_form_name }}
            <span class="form-required" aria-label="required">*</span>
          </label>
          <input type="text"
                 id="contact-name"
                 name="name"
                 autocomplete="name"
                 required>
        </div>

        <!-- Email -->
        <div class="form-group">
          <label for="contact-email">
            {{ t.contact_form_email }}
            <span class="form-required" aria-label="required">*</span>
          </label>
          <input type="email"
                 id="contact-email"
                 name="email"
                 autocomplete="email"
                 required>
        </div>

        <!-- Phone (optional) -->
        <div class="form-group">
          <label for="contact-phone">{{ t.contact_form_phone }}</label>
          <input type="tel"
                 id="contact-phone"
                 name="phone"
                 autocomplete="tel">
        </div>

        <!-- Message -->
        <div class="form-group">
          <label for="contact-message">
            {{ t.contact_form_message }}
            <span class="form-required" aria-label="required">*</span>
          </label>
          <textarea id="contact-message"
                    name="message"
                    rows="5"
                    required></textarea>
        </div>

        <div class="form-submit">
          <button type="submit" class="btn btn-primary">{{ t.contact_form_submit }}</button>
        </div>

      </form>

      <!-- Success message (shown by Netlify redirect or JS) -->
      <div class="form-success" role="alert">{{ t.contact_form_success }}</div>
    </div>
  </div>
</section>
