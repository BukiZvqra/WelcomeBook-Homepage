---
layout: base.njk
title: Пешеходни турове — TES Borovets
---
{% set lang = lang or "bg" %}
{% set t = i18n[lang] %}
{% set prefix = "" if lang == "bg" else "/en" %}
{% set serviceId = "hiking" %}
{% set currentService = client.services | selectattr("id", "equalto", serviceId) | first %}

<!-- Breadcrumb -->
<nav class="breadcrumb" aria-label="breadcrumb">
  <div class="container">
    <ol class="breadcrumb-list">
      <li><a href="{{ prefix }}/">{{ t.breadcrumb_home }}</a></li>
      <li>
        <span class="bc-sep" aria-hidden="true">›</span>
        <a href="{{ prefix }}/services/">{{ t.breadcrumb_services }}</a>
      </li>
      <li>
        <span class="bc-sep" aria-hidden="true">›</span>
        <span class="bc-current">{{ currentService.name }}</span>
      </li>
    </ol>
  </div>
</nav>

<!-- Hero -->
<section class="service-hero">
  {% if currentService.hero_image %}
  {% set heroUrl %}{% img currentService.hero_image, "hero" %}{% endset %}
  <img src="{{ heroUrl }}" alt="" class="service-hero-img" loading="eager" fetchpriority="high" decoding="async">
  {% endif %}
  <div class="service-hero-overlay"></div>
  <div class="container service-hero-content">
    <span class="kicker" style="color: var(--color-accent-200);">{{ t.breadcrumb_services }}</span>
    <h1>{{ currentService.name }}</h1>
    {% if lang == "bg" %}
      <p class="lead" style="color: rgba(255,255,255,0.85);">ТУР Експрес Сервиз Ви предлага пешеходни турове и невероятни преживявания</p>
    {% else %}
      <p class="lead" style="color: rgba(255,255,255,0.85);">TUR Express Service offers guided hiking tours and extraordinary experiences</p>
    {% endif %}
  </div>
</section>

<!-- Tours accordion -->
<section>
