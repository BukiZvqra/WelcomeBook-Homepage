---
layout: base.njk
title: TES Borovets — Боровец през всички сезони
---
{% set lang = lang or "bg" %}
{% set t = i18n[lang] %}
{% set prefix = "" if lang == "bg" else "/en" %}

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <img
      src="{% imgabs client.hero_image, 'hero' %}"
      alt="{{ client.business_name }}"
      loading="eager"
    >
  </div>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="hero-eyeline">
      <div class="hero-eyeline-bar"></div>
      <span class="hero-eyeline-label">BOROVETS</span>
    </div>
    <h1 class="hero-title">
      {% if lang == "en" %}Through every season{% else %}Боровец през всички сезони{% endif %}
    </h1>
    <p class="hero-subtitle">{{ client.tagline_subtitle }}</p>
    <div class="hero-cta">
      <a href="{{ prefix }}/apartments/" class="btn btn-gold">{{ t.hero_cta_primary }}</a>
      <a href="{{ prefix }}/contact/" class="btn btn-outline">{{ t.hero_cta_secondary }}</a>
    </div>
  </div>
</section>

<!-- EDITORIAL INTRO -->
<section class="intro-section">
  <div class="container">
    <div class="intro-grid reveal">
      <!-- Left: editorial interior photo -->
      <div class="intro-image-col">
        {% set introImg %}{% imgabs client.about_borovets_images[0], "hero" %}{% endset %}
        <img src="{{ introImg }}" alt="{{ client.business_name }}" loading="lazy">
      </div>
      <!-- Right: philosophy text -->
      <div class="intro-text-col">
        <span class="kicker">{{ "OUR PHILOSOPHY" if lang == "en" else "НАШАТА ФИЛОСОФИЯ" }}</span>
        <h2>{{ t.section_about_title }}</h2>
        <p class="section-subtitle" style="margin-top: var(--space-5);">{{ t.about_lead }}</p>
        <p style="margin-top: var(--space-4); color: var(--on-surface-variant);">{{ t.about_body }}</p>
        <p class="founder-quote">— {{ client.owner_name }}, Founder</p>
      </div>
    </div>
  </div>
</section>

<!-- BOUTIQUE COMPLEXES -->
<section id="complexes" style="padding-top: var(--section-v); padding-bottom: var(--section-v);">
  <div class="container">
    <div class="section-header reveal">
      <span class="kicker">{{ t.section_complexes_subtitle }}</span>
      <h2>{{ t.section_complexes_title }}</h2>
    </div>
  </div>
  <div style="max-width: var(--container-lg); margin: 0 auto; padding: 0 var(--margin-edge);">
    <div class="complexes-overlay-grid">
      {% for complex in client.complexes %}
        <a href="{{ prefix }}/apartments/?complex={{ complex.id }}" class="complex-overlay-card reveal reveal-delay-{{ loop.index }}">
          {% set complexImgUrl %}{% img complex.hero_image, "hero" %}{% endset %}
          <img src="{{ complexImgUrl }}" alt="{{ complex.name }}" loading="lazy">
          <div class="complex-overlay-gradient"></div>
          <div class="complex-overlay-content">
            <span class="kicker">
              {% set cpCount = properties | filterByComplex(complex.id) | length %}
              {{ complex.subtitle }} · {{ cpCount }} {{ "APT" if cpCount == 1 else "APTS" }}
            </span>
            <h3>{{ complex.name }}</h3>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CURATED SERVICES -->
<section class="services-preview" style="padding-top: var(--section-v); padding-bottom: var(--section-v);">
  <div class="container">
    <div class="section-header reveal text-center">
      <span class="kicker">{{ "CONCIERGE" if lang == "en" else "КОНСИЕРЖЕРИЯ" }}</span>
      <h2>{{ t.section_services_title }}</h2>
    </div>

    {% set symbolMap = {
      "property-manager": "apartment",
      "transfers": "airport_shuttle",
      "ski": "downhill_skiing",
      "team-building": "group",
      "safari": "explore",
      "hiking": "landscape"
    } %}

    <div class="services-editorial-grid">
      {% for service in client.services %}
        <a href="{{ prefix }}/services/{{ service.id }}/" class="service-editorial-cell reveal reveal-delay-{{ loop.index }}">
          <span class="material-symbols-outlined" aria-hidden="true">{{ symbolMap[service.id] or "star" }}</span>
          <span class="service-editorial-label">{{ service.name }}</span>
        </a>
      {% endfor %}
    </div>

    <div style="margin-top: var(--space-8); text-align: center;" class="reveal">
      <a href="{{ prefix }}/services/" class="btn btn-secondary">{{ t.services_cta }}</a>
    </div>
  </div>
</section>

<!-- BOROVETS TEASER -->
<section class="borovets-teaser">
  <div class="borovets-teaser-bg">
    <img
      src="{% imgabs client.about_borovets_images[4], 'hero' %}"
      alt="Borovets"
      loading="lazy"
    >
  </div>
  <div class="borovets-teaser-overlay"></div>
  <div class="borovets-teaser-content reveal">
    <span class="kicker" style="color: var(--color-accent-200);">BOROVETS</span>
    <h2>{{ t.section_borovets_title }}</h2>
    <a href="{{ prefix }}/about-borovets/" class="borovets-teaser-link">
      {{ t.section_borovets_cta }} →
    </a>
  </div>
</section>

<!-- TRUST STATS -->
<div class="trust-stats-section">
  <div class="trust-stats-grid" style="max-width: var(--container-lg); margin: 0 auto;">
    <div class="trust-stat reveal">
      <div class="trust-stat-number">{{ client.founded }}</div>
      <div class="trust-stat-label">{{ "Since" if lang == "en" else "Основана" }}</div>
    </div>
    <div class="trust-stat reveal reveal-delay-1">
      <div class="trust-stat-number">27</div>
      <div class="trust-stat-label">{{ "Apartments" if lang == "en" else "Апартамента" }}</div>
    </div>
    <div class="trust-stat reveal reveal-delay-2">
      <div class="trust-stat-number">4</div>
      <div class="trust-stat-label">{{ "Complexes" if lang == "en" else "Комплекса" }}</div>
    </div>
    <div class="trust-stat reveal reveal-delay-3">
      <div class="trust-stat-number">1000+</div>
      <div class="trust-stat-label">{{ "Happy Guests" if lang == "en" else "Доволни гости" }}</div>
    </div>
  </div>
</div>

<!-- CONTACT CTA -->
<section class="contact-cta-section" style="padding: var(--space-16) var(--space-6);">
  <div style="max-width: var(--container-sm); margin: 0 auto;" class="reveal">
    <span class="kicker" style="color: var(--color-accent-200);">{{ "READY TO BOOK?" if lang == "en" else "ГОТОВ ЗА РЕЗЕРВАЦИЯ?" }}</span>
    <h2>{{ t.section_contact_title }}</h2>
    <div style="margin-top: var(--space-6);">
      <p>{{ client.contact_phone_en }}</p>
      <p>{{ client.contact_email }}</p>
    </div>
    <div style="margin-top: var(--space-8);">
      <a href="{{ prefix }}/contact/" class="btn btn-gold">{{ t.hero_cta_secondary }}</a>
    </div>
  </div>
</section>
