---
layout: base.njk
pagination:
  data: properties
  size: 1
  alias: property
permalink: "/property/{{ property.slug }}/"
eleventyComputed:
  pageTitle: "data.property.name_bg"
---
{% set lang = lang or "bg" %}
{% set t = i18n[lang] %}
{% set prefix = "" if lang == "bg" else "/en" %}
{% set propertyName = property.name_bg if lang == "bg" else property.name_en %}
{% set propertyDesc = property.description_bg if lang == "bg" else property.description_en %}
{% set complexName = property.complex_name_bg if lang == "bg" else property.complex_name_en %}

{% set typeLabels = {
  "studio": t.type_studio,
  "1bedroom": t.type_1bedroom,
  "2bedroom": t.type_2bedroom,
  "double": t.type_double
} %}

{% set amenityLabels = {
  "wifi":             {"bg": "WiFi",              "en": "WiFi"},
  "tv":               {"bg": "Телевизор",         "en": "TV"},
  "kitchenette":      {"bg": "Кухненски кът",     "en": "Kitchenette"},
  "kitchen":          {"bg": "Кухня",             "en": "Kitchen"},
  "bathroom":         {"bg": "Баня",              "en": "Bathroom"},
  "balcony":          {"bg": "Балкон",            "en": "Balcony"},
  "heating":          {"bg": "Отопление",         "en": "Heating"},
  "air-conditioning": {"bg": "Климатик",          "en": "Air conditioning"},
  "washing-machine":  {"bg": "Перална машина",    "en": "Washing machine"},
  "parking":          {"bg": "Паркинг",           "en": "Parking"},
  "safe":             {"bg": "Сейф",              "en": "Safe"}
} %}

{% set amenitySymbols = {
  "wifi": "wifi",
  "tv": "tv",
  "kitchenette": "countertops",
  "kitchen": "countertops",
  "bathroom": "shower",
  "balcony": "balcony",
  "heating": "whatshot",
  "air-conditioning": "ac_unit",
  "washing-machine": "local_laundry_service",
  "parking": "local_parking",
  "safe": "lock"
} %}

{% set currentComplex = null %}
{% for c in client.complexes %}{% if c.id == property.complex %}{% set currentComplex = c %}{% endif %}{% endfor %}

<!-- Breadcrumb -->
<nav class="breadcrumb" aria-label="breadcrumb">
  <div class="container">
    <ol class="breadcrumb-list">
      <li><a href="{{ prefix }}/">{{ t.breadcrumb_home }}</a></li>
      <li>
        <span class="bc-sep" aria-hidden="true">›</span>
        <a href="{{ prefix }}/apartments/">{{ t.breadcrumb_apartments }}</a>
      </li>
      <li>
        <span class="bc-sep" aria-hidden="true">›</span>
        <span class="bc-current">{{ propertyName }}</span>
      </li>
    </ol>
  </div>
</nav>

<!-- Property Hero -->
{% if property.hero_image %}
  {% set heroImgUrl %}{% img property.hero_image, "hero" %}{% endset %}
  <div class="property-hero-image {{ property.complex }}-gradient"
       role="img"
       aria-label="{{ propertyName }}">
    <img src="{{ heroImgUrl }}"
         alt="{{ propertyName }}"
         loading="eager"
         fetchpriority="high"
         class="property-hero-img">
  </div>
{% else %}
  <div class="property-hero-image {{ property.complex }}-gradient"
       role="img"
       aria-label="{{ propertyName }}">
  </div>
{% endif %}

<!-- Photo Gallery -->
{% if property.images and property.images | length > 0 %}
<section class="property-gallery">
  <div class="container">

    <!-- Desktop + Tablet: Hero + Mosaic grid -->
    <div class="gallery-mosaic-wrapper">
      <div class="gallery-mosaic">
        {% for imgPath in property.images %}
          {% if loop.index == 1 %}
            {% set _u %}{% img imgPath, "hero" %}{% endset %}
            <div class="gallery-cell gallery-hero" data-index="0" role="button" tabindex="0" aria-label="{{ propertyName }} — главна снимка">
              <img src="{{ _u }}" alt="" aria-hidden="true" loading="eager" class="gallery-img">
            </div>
          {% elif loop.index <= 5 %}
            {% set _u %}{% img imgPath, "thumb" %}{% endset %}
            <div class="gallery-cell gallery-thumb gallery-thumb-{{ loop.index }}" data-index="{{ loop.index0 }}" role="button" tabindex="0" aria-label="{{ propertyName }} — снимка {{ loop.index }}">
              <img src="{{ _u }}" alt="" aria-hidden="true" loading="lazy" decoding="async" class="gallery-img">
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <button class="gallery-view-all" id="gallery-open-btn" type="button" aria-label="{{ t.gallery_view_all }}">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
          <rect x="0" y="0" width="6" height="6" rx="1" fill="currentColor"/>
          <rect x="8" y="0" width="6" height="6" rx="1" fill="currentColor"/>
          <rect x="0" y="8" width="6" height="6" rx="1" fill="currentColor"/>
          <rect x="8" y="8" width="6" height="6" rx="1" fill="currentColor"/>
        </svg>
        {{ t.gallery_view_all }}
        <span class="gallery-count-badge">{{ property.images | length }}</span>
      </button>
    </div>

    <!-- Mobile: Swipeable carousel -->
    <div class="gallery-carousel" role="region" aria-label="{{ propertyName }} — галерия">
      <div class="gallery-carousel-track" id="gallery-track">
        {% for imgPath in property.images %}
          {% set _u %}{% img imgPath, "thumb" %}{% endset %}
          <div class="gallery-carousel-slide" data-index="{{ loop.index0 }}" role="button" tabindex="0" aria-label="{{ propertyName }} — снимка {{ loop.index }}">
            <img src="{{ _u }}" alt="{{ propertyName }} — снимка {{ loop.index }}" loading="{{ 'eager' if loop.first else 'lazy' }}" decoding="async" class="gallery-img">
          </div>
        {% endfor %}
      </div>
      <div class="gallery-counter" aria-live="polite">
        <span id="gallery-current">1</span> / {{ property.images | length }}
      </div>
      <div class="gallery-dots" role="tablist" aria-label="Навигация на галерията">
        {% for imgPath in property.images %}
          <button class="gallery-dot{% if loop.first %} active{% endif %}" role="tab" aria-selected="{{ 'true' if loop.first else 'false' }}" aria-label="Снимка {{ loop.index }}" data-index="{{ loop.index0 }}"></button>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<!-- Lightbox -->
<div class="gallery-lightbox" id="gallery-lightbox" role="dialog" aria-modal="true" aria-label="Галерия снимки" tabindex="-1" hidden>
  <div class="gallery-lb-overlay"></div>
  <button class="gallery-lb-close" aria-label="Затвори галерията">&#x2715;</button>
  <div class="gallery-lb-counter" id="lb-counter" aria-live="polite"></div>
  <div class="gallery-lb-inner">
    <img src="" alt="" id="lb-img" class="gallery-lb-img">
  </div>
  <button class="gallery-lb-prev" aria-label="Предишна снимка">&#x2039;</button>
  <button class="gallery-lb-next" aria-label="Следваща снимка">&#x203a;</button>
</div>

<script>
(function () {
  var IMAGES = [
    {% for imgPath in property.images %}
    {% set _f %}{% img imgPath, "full" %}{% endset %}
    { "full": "{{ _f }}" }{% if not loop.last %},{% endif %}
    {% endfor %}
  ];
  var total = IMAGES.length;
  var cur   = 0;
  var lb    = document.getElementById('gallery-lightbox');
  var lbImg = document.getElementById('lb-img');
  var lbCtr = document.getElementById('lb-counter');
  var track = document.getElementById('gallery-track');
  var curEl = document.getElementById('gallery-current');
  var dots  = document.querySelectorAll('.gallery-dot');

  if (track) {
    track.addEventListener('scroll', function () {
      var w = track.offsetWidth || 1;
      var idx = Math.max(0, Math.min(Math.round(track.scrollLeft / w), total - 1));
      if (curEl) curEl.textContent = idx + 1;
      dots.forEach(function (d, i) {
        d.classList.toggle('active', i === idx);
        d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
    }, { passive: true });
  }

  window.galleryGoTo = function (idx) {
    if (track) track.scrollTo({ left: idx * (track.offsetWidth || 0), behavior: 'smooth' });
  };

  function lbShow() {
    lbImg.src = ''; lbImg.src = IMAGES[cur].full;
    lbImg.alt = 'Снимка ' + (cur + 1) + ' от ' + total;
    lbCtr.textContent = (cur + 1) + ' / ' + total;
  }

  window.galleryLightboxOpen = function (idx) {
    cur = Math.max(0, Math.min(idx, total - 1));
    lb.hidden = false; document.body.style.overflow = 'hidden';
    lbShow(); lb.focus();
  };

  window.galleryLightboxClose = function () {
    lb.hidden = true; document.body.style.overflow = '';
  };

  window.galleryLightboxNav = function (dir) {
    cur = (cur + dir + total) % total; lbShow();
  };

  document.addEventListener('keydown', function (e) {
    if (lb.hidden) return;
    if (e.key === 'Escape') galleryLightboxClose();
    else if (e.key === 'ArrowLeft')  galleryLightboxNav(-1);
    else if (e.key === 'ArrowRight') galleryLightboxNav(1);
  });

  var startX = 0;
  lb.addEventListener('pointerdown', function (e) { startX = e.clientX; }, { passive: true });
  lb.addEventListener('pointerup',   function (e) {
    if (Math.abs(e.clientX - startX) > 50) galleryLightboxNav(e.clientX < startX ? 1 : -1);
  });

  document.querySelectorAll('.gallery-cell').forEach(function (c) {
    c.addEventListener('click', function () { galleryLightboxOpen(+c.dataset.index); });
    c.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); galleryLightboxOpen(+c.dataset.index); }
    });
  });
  document.querySelectorAll('.gallery-carousel-slide').forEach(function (s) {
    s.addEventListener('click', function () { galleryLightboxOpen(+s.dataset.index); });
  });
  dots.forEach(function (d) {
    d.addEventListener('click', function () { galleryGoTo(+d.dataset.index); });
  });

  var btn = document.getElementById('gallery-open-btn');
  if (btn) btn.addEventListener('click', function () { galleryLightboxOpen(0); });

  lb.querySelector('.gallery-lb-overlay').addEventListener('click', galleryLightboxClose);
  lb.querySelector('.gallery-lb-close').addEventListener('click',   galleryLightboxClose);
  lb.querySelector('.gallery-lb-prev').addEventListener('click',    function () { galleryLightboxNav(-1); });
  lb.querySelector('.gallery-lb-next').addEventListener('click',    function () { galleryLightboxNav(1); });
})();
</script>
{% endif %}

<!-- Property Detail -->
<section class="property-detail-section">
  <div class="container">
    <div class="property-detail-grid">

      <!-- Main Info -->
      <div>
        <h1>{{ propertyName }}</h1>
        <p class="property-complex-label">{{ complexName }}</p>

        <!-- Specs -->
        <div class="property-specs">
          <span class="property-spec">
            <span class="material-symbols-outlined" aria-hidden="true">bed</span>
            {{ typeLabels[property.type] or property.type }}
          </span>
          <span class="property-spec">
            <span class="material-symbols-outlined" aria-hidden="true">group</span>
            {{ property.capacity }} {{ t.property_guests_suffix }}
          </span>
          {% if property.size_sqm %}
          <span class="property-spec">
            <span class="material-symbols-outlined" aria-hidden="true">straighten</span>
            {{ property.size_sqm }} м²
          </span>
          {% endif %}
        </div>

        <!-- Description -->
        <p class="property-description">{{ propertyDesc }}</p>
      </div>

      <!-- Contact Sidebar -->
      <aside class="property-contact-box">
        <span class="kicker">{{ "CONTACT" if lang == "en" else "КОНТАКТ" }}</span>
        <div class="contact-phone-row">
          <a href="tel:{{ client.contact_phone_en }}" class="contact-phone-number">{{ client.contact_phone_en }}</a>
        </div>
        <div class="contact-channel-row">
          <a href="viber://chat?number=+359888909237" class="contact-channel-link" aria-label="Viber">
            <span class="material-symbols-outlined" aria-hidden="true">phone_iphone</span>
            Viber
          </a>
          <a href="https://wa.me/359888909237" target="_blank" rel="noopener" class="contact-channel-link" aria-label="WhatsApp">
            <span class="material-symbols-outlined" aria-hidden="true">chat</span>
            WhatsApp
          </a>
        </div>
        <a href="{{ prefix }}/contact/" class="btn btn-primary contact-inquire-btn">
          {{ "INQUIRE" if lang == "en" else "ЗАПИТВАНЕ" }}
        </a>
      </aside>

    </div>
  </div>
</section>

<!-- Complex Hero Banner (full-bleed cinematic) -->
{% if currentComplex and currentComplex.hero_complex_image %}
<a href="{{ prefix }}/apartments/?complex={{ currentComplex.id }}" class="complex-hero-banner" aria-label="{{ 'About' if lang == 'en' else 'За' }} {{ currentComplex.name }}">
  {% set complexHeroUrl %}{% imgabs currentComplex.hero_complex_image, "banner" %}{% endset %}
  <img src="{{ complexHeroUrl }}" alt="{{ currentComplex.name }}" loading="lazy" decoding="async" class="complex-hero-banner-img">
  <div class="complex-hero-banner-overlay"></div>
  <div class="complex-hero-banner-content">
    <span class="kicker">{{ "ABOUT THE COMPLEX" if lang == "en" else "ЗА КОМПЛЕКСА" }}</span>
    <h2>{{ currentComplex.name }}</h2>
    {% if currentComplex.tagline %}
      <p class="complex-hero-banner-tagline">{{ currentComplex.tagline }}</p>
    {% endif %}
  </div>
</a>
{% endif %}

<!-- Amenities + Complex Info + Similar -->
<section class="property-lower-section">
  <div class="container">

    <!-- Amenities -->
    {% if property.amenities and property.amenities.length > 0 %}
    <div class="property-amenities-section">
      <h3>{{ t.property_amenities_label }}</h3>
      <div class="amenities-grid">
        {% for amenity in property.amenities %}
          {% set amenLabel = amenityLabels[amenity] %}
          <div class="amenity-item">
            <span class="material-symbols-outlined" aria-hidden="true">{{ amenitySymbols[amenity] or "check_circle" }}</span>
            {{ amenLabel[lang] if amenLabel else amenity | replace("-", " ") | title }}
          </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <!-- Complex Info -->
    {% if currentComplex and currentComplex['description_' + lang] %}
    <div class="complex-info-box">
      <h3 class="complex-info-title">
        {{ "About" if lang == "en" else "За" }} {{ currentComplex.name }}
      </h3>
      <p class="complex-info-desc">{{ currentComplex['description_' + lang] }}</p>
      {% set complexAmenities = currentComplex['amenities_' + lang] %}
      {% if complexAmenities and complexAmenities.length > 0 %}
        <div class="property-amenities" style="margin-top: var(--space-5);">
          {% for item in complexAmenities %}
            <span class="amenity-tag">&#x2713; {{ item }}</span>
          {% endfor %}
        </div>
      {% endif %}
      {% if currentComplex['location_' + lang] %}
        <p class="complex-info-location">
          <span class="material-symbols-outlined" aria-hidden="true">location_on</span>
          {{ currentComplex['location_' + lang] }}
        </p>
      {% endif %}
    </div>
    {% endif %}

    <!-- Similar Properties -->
    {% set allFromComplex = properties | selectattr("complex", "equalto", property.complex) %}
    {% set relatedProps = allFromComplex | rejectattr("slug", "equalto", property.slug) %}
    {% if relatedProps | length > 0 %}
      <div style="margin-top: var(--space-9);">
        <h2>{{ t.property_similar_label }}</h2>
        <div class="property-grid">
          {% for property in relatedProps | batch(3) | first %}
            {% include "property-card.njk" %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>
</section>
