{# Property card include
   Variables: property (object), prefix (lang prefix), t (i18n), lang #}

{% set typeLabels = {
  "studio": t.type_studio,
  "1bedroom": t.type_1bedroom,
  "2bedroom": t.type_2bedroom,
  "double": t.type_double
} %}

<article class="property-card"
         data-capacity="{{ property.capacity }}"
         data-complex="{{ property.complex }}"
         data-type="{{ property.type }}">
  <div class="property-card-image {{ property.complex }}-gradient" role="img" aria-label="{{ property.name_en if lang == 'en' else property.name_bg }}">
    {% if property.hero_image %}
      {% set cardImgUrl %}{% img property.hero_image %}{% endset %}
      <img src="{{ cardImgUrl }}" alt="" aria-hidden="true" loading="lazy" class="property-card-bg-img">
    {% endif %}
    <span class="property-type-badge">{{ typeLabels[property.type] or property.type }}</span>
  </div>
  <div class="property-card-body">
    <h3>{{ property.name_en if lang == "en" else property.name_bg }}</h3>
    <div class="property-card-meta">
      <span title="{{ t.property_capacity_label }}">👥 {{ property.capacity }} {{ t.property_guests_suffix }}</span>
      {% if property.size_sqm %}
        <span title="{{ t.property_size_label }}">📐 {{ property.size_sqm }} м²</span>
      {% endif %}
      <span>{{ property.complex_name_en if lang == "en" else property.complex_name_bg }}</span>
    </div>
    <p>{{ (property.description_en if lang == "en" else property.description_bg) | truncate(100) }}</p>
    <a href="{{ prefix }}/property/{{ property.slug }}/" class="btn btn-secondary btn-sm">
      {{ t.btn_view_more }}
    </a>
  </div>
</article>
