      {% set showDesc = false %}
      {% for service in client.services %}
        {% if service.id != serviceId %}
          {% include "service-card.njk" %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function () {
  var items = document.querySelectorAll('#hiking-accordion .accordion-item');
  items.forEach(function (item) {
    var btn = item.querySelector('.accordion-header');
    var body = item.querySelector('.accordion-body');
    if (!btn || !body) return;
    if (item.classList.contains('open')) {
      body.style.maxHeight = body.scrollHeight + 'px';
    }
    btn.addEventListener('click', function () {
      var isOpen = item.classList.contains('open');
      items.forEach(function (other) {
        other.classList.remove('open');
        other.querySelector('.accordion-header').setAttribute('aria-expanded', 'false');
        other.querySelector('.accordion-body').style.maxHeight = '0';
        var icon = other.querySelector('.accordion-icon');
        if (icon) icon.textContent = '+';
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
        var icon = btn.querySelector('.accordion-icon');
        if (icon) icon.textContent = '×';
      }
    });
  });
})();
</script>
