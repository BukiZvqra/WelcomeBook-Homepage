---
layout: base.njk
title: Тиймбилдинг — TES Borovets
---
{% set lang = lang or "bg" %}
{% set t = i18n[lang] %}
{% set prefix = "" if lang == "bg" else "/en" %}
{% set serviceId = "team-building" %}
{% set currentService = client.services | selectattr("id", "equalto", serviceId) | first %}

<!-- Breadcrumb -->
<nav class="breadcrumb" aria-label="breadcrumb">
  <div class="container">
    <ol class="breadcrumb-list">
      <li><a href="{{ prefix }}/">{{ t.breadcrumb_home }}</a></li>
      <li>
        <span class="bc-sep" aria-hidden="true">›</span>
        <a href="{{ prefix }}/services/">{{ t.breadcrumb_services }}</a>
      </li>
      <li>
        <span class="bc-sep" aria-hidden="true">›</span>
        <span class="bc-current">{{ currentService.name }}</span>
      </li>
    </ol>
  </div>
</nav>

<!-- Hero -->
<section class="service-hero">
  {% if currentService.hero_image %}
  {% set heroUrl %}{% img currentService.hero_image, "hero" %}{% endset %}
  <img src="{{ heroUrl }}" alt="" class="service-hero-img" loading="eager" fetchpriority="high" decoding="async">
  {% endif %}
  <div class="service-hero-overlay"></div>
  <div class="container service-hero-content">
    <span class="kicker" style="color: var(--color-accent-200);">{{ t.breadcrumb_services }}</span>
    <h1>{{ currentService.name }}</h1>
    {% if lang == "bg" %}
      <p class="lead" style="color: rgba(255,255,255,0.85);">Тур-Експрес-Сервис ООД, може да организира Вашият Тиймбилдинг в района на Боровец</p>
    {% else %}
      <p class="lead" style="color: rgba(255,255,255,0.85);">Tour Express Service Ltd. can organise your team building in the Borovets area</p>
    {% endif %}
  </div>
</section>

<!-- Content -->
<section>
  <div class="container">
    <div style="max-width: var(--container-md);">
      {% if lang == "bg" %}
        <p class="lead">Тур-Експрес-Сервис ООД е Вашият идеален партньор в организирането на фирмен Тиймбилдинг в района на Боровец.</p>
        <p style="margin-top: var(--space-7); line-height: 1.75;">Боровец предлага идеалните условия за корпоративни събития сред природата — от outdoor приключения до екипни дейности в комфортна среда. Нашият екип организира цялата логистика: настаняване, храна, активности и транспорт, така че гостите да се фокусират върху изграждане на отношения.</p>
      {% else %}
        <p class="lead">Tour Express Service Ltd. is your ideal partner for organising a corporate team building event in the Borovets area.</p>
        <p style="margin-top: var(--space-7); line-height: 1.75;">Borovets provides ideal conditions for corporate events in nature — from outdoor adventures to team activities in a comfortable setting. Our team handles the entire logistics: accommodation, catering, activities and transport, so guests can focus on building relationships.</p>
      {% endif %}

      <p style="margin-top: var(--space-8); color: var(--color-neutral-500); font-size: var(--text-sm);">{{ t.service_pricing_note }}</p>
    </div>
  </div>
</section>

<!-- Contact -->
<section class="section-alt">
  <div class="container">
    <h2>{{ t.contact_methods_title }}</h2>
    {% include "contact-methods.njk" %}
  </div>
</section>

<!-- Related Services -->
<section>
  <div class="container">
    <h2>{{ t.service_related_label }}</h2>
    <div class="services-grid" style="margin-top: var(--space-6);">
      {% set showDesc = false %}
      {% for service in client.services %}
        {% if service.id != serviceId %}
          {% include "service-card.njk" %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
