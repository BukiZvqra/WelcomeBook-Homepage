{# Contact methods include
   Shows: phone EN, phone RU, Viber, WhatsApp, email
   Variables: t (i18n), client (global) #}

<div class="contact-grid">

  <a href="tel:{{ client.contact_phone_en }}" class="contact-card">
    <span class="contact-card-icon" aria-hidden="true">
      <span class="material-symbols-outlined">call</span>
    </span>
    <div class="contact-card-body">
      <h3>{{ t.contact_phone_en_label }}</h3>
      <p>{{ client.contact_phone_en }}</p>
    </div>
  </a>

  <a href="tel:{{ client.contact_phone_ru }}" class="contact-card">
    <span class="contact-card-icon" aria-hidden="true">
      <span class="material-symbols-outlined">call</span>
    </span>
    <div class="contact-card-body">
      <h3>{{ t.contact_phone_ru_label }}</h3>
      <p>{{ client.contact_phone_ru }}</p>
    </div>
  </a>

  <a href="mailto:{{ client.contact_email }}" class="contact-card">
    <span class="contact-card-icon" aria-hidden="true">
      <span class="material-symbols-outlined">mail</span>
    </span>
    <div class="contact-card-body">
      <h3>{{ t.contact_email_label }}</h3>
      <p>{{ client.contact_email }}</p>
    </div>
  </a>

  <a href="viber://chat?number=+359888909237" class="contact-card">
    <span class="contact-card-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.5 13a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
    </span>
    <div class="contact-card-body">
      <h3>{{ t.contact_viber_label }}</h3>
      <p>{{ client.contact_phone_en }}</p>
    </div>
  </a>

  <a href="https://wa.me/359888909237" class="contact-card" target="_blank" rel="noopener">
    <span class="contact-card-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>
      </svg>
    </span>
    <div class="contact-card-body">
      <h3>{{ t.contact_whatsapp_label }}</h3>
      <p>{{ client.contact_phone_en }}</p>
    </div>
  </a>

</div>
